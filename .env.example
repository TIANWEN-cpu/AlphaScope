# AI-Finance Environment Variables
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control

# ============== LLM Provider Keys ==============
# DeepSeek (required, fallback provider)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_BASE_URL=https://api.anthropic.com

# GPT (OpenAI)
GPT_API_KEY=sk-xxx
GPT_BASE_URL=https://api.openai.com

# Mimo (Xiaomi)
MIMO_API_KEY=xxx
MIMO_BASE_URL=https://api.mimo.ai

# SenseNova
SENSENOVA_API_KEY=xxx
SENSENOVA_BASE_URL=https://api.sensenova.cn

# Kimi (Moonshot)
KIMI_API_KEY=sk-xxx
KIMI_BASE_URL=https://api.moonshot.cn

# ============== Data Provider Keys ==============
# Finnhub (free tier: 60 req/min)
FINNHUB_API_KEY=xxx

# FRED (Federal Reserve Economic Data, free)
FRED_API_KEY=xxx

# Tushare Pro
TUSHARE_TOKEN=xxx

# ============== Optional Settings ==============
# Allow local/custom LLM base URLs (security risk in production)
ALLOW_LOCAL_LLM_BASE_URL=0

# Streamlit server config
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-finance

# ============== Custom Provider Keys ==============
# Add your custom data source API keys here
# See custom_providers/README.md for how to create custom providers
# MY_CUSTOM_API_KEY=xxx
