# GEMINI_API_KEY: optional, used only by Gemini-powered features.
# Set this in your local environment when needed. Do not commit real keys.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Backend API base URL used by the React app.
VITE_API_BASE_URL="http://localhost:8000"

# VITE_USE_MOCK_REPORT: Set to "true" only when intentionally demoing the
# report UI without a backend. Development now uses the real backend by default.
VITE_USE_MOCK_REPORT="false"
